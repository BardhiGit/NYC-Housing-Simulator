# Copy to .env and fill in values
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nyc_housing
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/nyc_housing
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
